# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Public Keys
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Python Worker Credentials
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
APIFY_TOKEN="your-apify-token"

# Phase 1 Auth scaffold — see docs/superpowers/specs/2026-04-23-phase-1-overhaul-design.md §6.1
# Hardcoded "system user" used by server actions until real Supabase Auth is wired up.
# Set this to a real auth.users.id UUID. Find one via:
#   SELECT id, email FROM auth.users ORDER BY created_at LIMIT 5;
SYSTEM_USER_ID="00000000-0000-0000-0000-000000000001"

# Optional: short-circuits getCurrentWorkspaceId() DB lookup. If unset, the helper picks
# the oldest workspace in the DB. Set explicitly in production for determinism.
DEFAULT_WORKSPACE_ID="00000000-0000-0000-0000-000000000010"