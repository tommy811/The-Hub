SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-api-key
APIFY_TOKEN=your-apify-token
POLL_INTERVAL_SECONDS=30
MAX_CONCURRENT_RUNS=5
# Direct DB connection for psql (port 5432, not the pooler). Get from:
# Supabase Dashboard → Project Settings → Database → URI
SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# Sentry MCP (optional)
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=

# Slack webhook for runtime alerts (Phase 2+)
SLACK_WEBHOOK_URL_ALERTS=

# Apify webhook targets (Phase 2+, set when ingestion goes live)
APIFY_WEBHOOK_URL_EMPTY_DATASET=
APIFY_WEBHOOK_URL_FAILED=
